[user]
	name = Jingyue Wu
	email = wujingyue@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub
[diff]
	color = auto
[color]
	ui = true
[core]
	editor = vim
[push]
	default = matching
[branch "master"]
	rebase = true
[gpg]
	format = ssh
[commit]
	gpgsign = true
[delta]
	features = line-numbers
	syntax-theme = GitHub
[pager]
	diff = delta --paging=always 2>/dev/null || less
	show = delta --paging=always 2>/dev/null || less
